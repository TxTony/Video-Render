{
  "name": "videorender",
  "version": "1.0.0",
  "author": "TxTony",
  "description": "Turn album art + audio into YouTube-ready videos",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.videorender.app",
    "productName": "VideoRender",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "icon.ico",
      "icon.png"
    ],
    "extraResources": [
      {
        "from": "ffmpeg/",
        "to": "ffmpeg",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "TxTony",
      "repo": "Video-Render"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "png-to-ico": "^3.0.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
